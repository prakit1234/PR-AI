# HUGGING_FACE_ACCESS_TOKEN: Required for Hugging Face Inference API.
# Users can get this from https://huggingface.co/settings/tokens
HUGGING_FACE_ACCESS_TOKEN=""

# FEATHERLESS_API_KEY: Required for Featherless AI API calls.
FEATHERLESS_API_KEY=""

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string (NeonDB) for public character registry
DATABASE_URL=""
